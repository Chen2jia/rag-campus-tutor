APP_NAME=EduMate
APP_ENV=development
API_PREFIX=/api

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/edumate
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=knowledge_chunks
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
OPENAI_API_KEY=sk-change-me
OPENAI_MODEL=
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=52428800
FORMULA_OCR_ENABLED=false
FORMULA_OCR_ENGINE=pix2tex
FORMULA_OCR_MIN_CONFIDENCE=0.7

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

BACKEND_CORS_ORIGINS=http://localhost:5173
